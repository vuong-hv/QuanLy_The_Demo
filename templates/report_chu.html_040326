<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>Báo cáo Chủ POS</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
    <style>
        body { background-color: #f0f2f5; font-size: 10px; }
        .money { text-align: right; font-weight: bold; white-space: nowrap; padding: 8px 4px !important; }
        .table thead th { background-color: #0d6efd; color: white; text-align: center; }
        .total-row td { color: #198754 !important; font-weight: 900 !important; background-color: #e9ecef !important; border-top: 2px solid #198754; border-bottom: 2px solid #198754; font-size: 11px; }
        .btn-edit-row { background-color: #f8f9fa; border: 1px solid #ced4da; padding: 2px 6px; border-radius: 5px; text-decoration: none; color: #198754; font-weight: bold; }
    </style>
</head>
<body class="container-fluid py-2">
    <div class="d-flex justify-content-between mb-2"><h6>📊 BÁO CÁO CHỦ POS</h6><a href="/" class="btn btn-sm btn-primary">Quay lại</a></div>
    
    <form action="/report_chu" method="get" class="row g-1 mb-2">
        <div class="col-4"><input type="date" name="date" class="form-control form-control-sm" value="{{sel_date}}"></div>
        <div class="col-5"><select name="chu_pos" class="form-select form-select-sm">
            <option value="Tất cả">-- Chủ POS --</option>{% for c in list_chu %}<option value="{{c}}" {% if sel_chu==c %}selected{% endif %}>{{c}}</option>{% endfor %}
        </select></div>
        <div class="col-3"><button type="submit" class="btn btn-success btn-sm w-100">LỌC</button></div>
    </form>

    <div class="table-responsive bg-white rounded shadow-sm">
        <table class="table table-sm table-bordered mb-0">
            <thead>
                <tr>
                    <th>Sửa</th> <!-- CỘT SỬA MỚI -->
                    <th>Ngày</th><th>Chủ</th><th>Lô</th><th>Lãi</th><th>Tiền</th><th>P.K</th><th>S.P.K</th><th>Thực</th><th>Ghi chú</th>
                </tr>
            </thead>
            <tbody>
                {% for item in report_data %}
                <tr class="{% if item.is_total %}total-row{% endif %}">
                    <td class="text-center">
                        {% if not item.is_total %}
                        <a href="/edit_transaction/{{ item.idx }}" class="btn-edit-row">✎ Sửa</a>
                        {% endif %}
                    </td>
                    <td class="text-center">{{ item.row['Chi tiết ngày tháng'] if not item.is_total else 'TỔNG' }}</td>
                    <td class="fw-bold">{{ item.row['Tên Chủ POS'] }}</td>
                    <td class="text-center">{{ item.row['Số Lô'] }}</td>
                    <td class="money {% if item.val.lai_lo < 0 %}text-danger{% endif %}">{{ "{:,.0f}".format(item.val.lai_lo) }}</td>
                    <td class="money">{{ "{:,.0f}".format(item.val.so_tien) }}</td>
                    <td class="money text-muted">{{ "{:,.0f}".format(item.val.phi_k) }}</td>
                    <td class="money">{{ "{:,.0f}".format(item.val.sau_phi_k) }}</td>
                    <td class="money text-primary">
                        {{ "{:,.0f}".format(item.val.thuc_chuyen) }}
                        {% if not item.is_total %}<br><a href="javascript:void(0)" class="text-success text-decoration-none" style="font-size:9px" onclick="showT('{{item.key}}')">+Cộng</a>
                        <form action="/add_transfer" method="post" id="t-{{item.key}}" style="display:none;"><input type="hidden" name="key" value="{{item.key}}"><input type="text" name="amount_to_add" class="form-control form-control-sm mb-1" oninput="formatCur(this)" placeholder="0"><button class="btn btn-success btn-sm w-100 py-0">Lưu</button></form>{% endif %}
                    </td>
                    <td style="background:#fff9db; min-width:130px;">
                        {% if not item.is_total %}
                        <div id="d-{{item.key}}" class="d-flex justify-content-between align-items-start"><span>{{item.note}}</span><button class="btn btn-warning btn-sm py-0 px-1" onclick="openE('{{item.key}}')">Ghi chú</button></div>
                        <form action="/save_note" method="post" id="f-{{item.key}}" style="display:none;"><input type="hidden" name="key" value="{{item.key}}"><textarea name="note" class="form-control form-control-sm mb-1">{{item.note}}</textarea><button class="btn btn-success btn-sm w-100 py-0">Lưu</button></form>
                        {% endif %}
                    </td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
    <script>
        function openE(k){document.getElementById('d-'+k).className='d-none'; document.getElementById('f-'+k).style.display='block';}
        function showT(k){document.getElementById('t-'+k).style.display='block';}
        function formatCur(i){let v=i.value.replace(/\D/g,""); if(v!=="")i.value=Number(v).toLocaleString('en-US');}
    </script>
</body>
</html>
