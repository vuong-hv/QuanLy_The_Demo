<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Chi tiết</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
    <style>body{font-size:10px;} thead{background:#212529; color:white;}</style>
</head>
<body class="p-2">
    <div class="d-flex justify-content-between mb-2"><h6>DANH SÁCH CHI TIẾT</h6><a href="/" class="btn btn-primary btn-sm">Quay lại</a></div>
    <div class="table-responsive">
        <table class="table table-bordered table-sm">
            <thead><tr><th>Ngày</th><th>Chủ</th><th>Máy</th><th>Tiền</th><th>Thực</th><th>Lãi</th><th>Xóa</th></tr></thead>
            <tbody>
                {% for row in transactions %}
                <tr>
                    <td>{{ row['Chi tiết ngày tháng'] }}</td><td>{{ row['Tên Chủ POS'] }}</td><td>{{ row['Máy POS'] }}</td>
                    <td class="text-end">{{ "{:,.0f}".format(row['Số tiền']) }}</td><td class="text-end">{{ "{:,.0f}".format(row['Thực chuyển']) }}</td>
                    <td class="text-end {% if row['Lãi/Lỗ'] < 0 %}text-danger{% endif %}">{{ "{:,.0f}".format(row['Lãi/Lỗ']) }}</td>
                    <td class="text-center"><a href="/delete_transaction/{{ row['index'] }}" class="text-danger fw-bold" onclick="return confirm('Xóa dòng này?')">X</a></td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
</body>
</html>
