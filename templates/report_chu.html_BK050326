<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>Báo cáo Chủ POS</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
    <style>
        body { background-color: #f0f2f5; font-size: 14px; }
        @media (max-width: 768px) { body { font-size: 10px; } .money { font-size: 10px; } }
        .money { text-align: right; font-weight: bold; white-space: nowrap; }
        .table thead th { background-color: #0d6efd !important; color: white; text-align: center; cursor: help; }
        .total-row td { color: #198754 !important; font-weight: 900 !important; background-color: #e9ecef !important; border-top: 2px solid #198754; border-bottom: 2px solid #198754; }
        .note-cell { min-width: 130px; background-color: #fff9db; }
    </style>
</head>
<body class="container-fluid py-2">
    <div class="d-flex justify-content-between mb-2"><h6>📊 TỔNG HỢP CHỦ POS</h6><a href="/" class="btn btn-sm btn-primary">Quay lại</a></div>
    
    <form action="/report_chu" method="get" class="row g-1 mb-2 card p-2 border-0 shadow-sm mx-0">
        <div class="col-4"><input type="date" name="date" class="form-control form-control-sm" value="{{sel_date}}"></div>
        <div class="col-5"><select name="chu_pos" class="form-select form-select-sm">
            <option value="Tất cả">-- Chủ --</option>{% for c in list_chu %}<option value="{{c}}" {% if sel_chu==c %}selected{% endif %}>{{c}}</option>{% endfor %}
        </select></div>
        <div class="col-3"><button type="submit" class="btn btn-success btn-sm w-100">LỌC</button></div>
    </form>

    <div class="table-responsive bg-white rounded shadow-sm">
        <table class="table table-sm table-bordered mb-0">
            <thead>
                <tr>
                    <th>Sửa</th><th>Ngày</th><th>Chủ</th><th>Lô</th>
                    <th title="Lãi = Phí thu khách - Phí trả Công ty">Lợi nhuận</th>
                    <th>Số tiền quẹt</th><th>Phí thu khách</th><th>Sau phí khách</th><th>Thực chuyển khách</th><th>Ghi chú</th>
                </tr>
            </thead>
            <tbody>
                {% for item in report_data %}
                <tr class="{% if item.is_total %}total-row{% endif %}">
                    <td class="text-center">{% if not item.is_total %}<a href="/edit_transaction/{{ item.idx }}" class="text-success text-decoration-none">✎</a>{% endif %}</td>
                    <td class="text-center small">{{ item.row['Chi tiết ngày tháng'] if not item.is_total else 'TỔNG' }}</td>
                    <td class="small">{{ item.row['Tên Chủ POS'] }}</td>
                    <td class="text-center">{{ item.row['Số Lô'] }}</td>
                    <td class="money {% if item.val.lai_lo < 0 %}text-danger{% endif %}">{{ "{:,.0f}".format(item.val.lai_lo) }}</td>
                    <td class="money">{{ "{:,.0f}".format(item.val.so_tien) }}</td>
                    <td class="money text-muted">{{ "{:,.0f}".format(item.val.phi_k) }}</td>
                    <td class="money">{{ "{:,.0f}".format(item.val.sau_phi_k) }}</td>
                    <td class="money text-primary">
                        {{ "{:,.0f}".format(item.val.thuc_chuyen) }}
                        {% if not item.is_total %}<br><a href="javascript:void(0)" class="text-success text-decoration-none" style="font-size:9px" onclick="showT('{{item.key}}')">+ Cộng</a>
                        <div id="t-{{item.key}}" style="display:none;" class="mt-1"><form action="/add_transfer" method="post" class="d-flex gap-1"><input type="hidden" name="key" value="{{item.key}}"><input type="text" name="amount_to_add" class="form-control form-control-sm p-0" oninput="formatCur(this)" style="width:70px"><button class="btn btn-success btn-sm p-0 px-1">ok</button></form></div>{% endif %}
                    </td>
                    <td class="note-cell small">
                        {% if not item.is_total %}
                        <div id="d-{{item.key}}" class="d-flex justify-content-between align-items-start"><span>{{item.note}}</span><button class="btn btn-warning btn-sm py-0 px-1" onclick="openE('{{item.key}}')">✎</button></div>
                        <form action="/save_note" method="post" id="f-{{item.key}}" style="display:none;"><input type="hidden" name="key" value="{{item.key}}"><textarea name="note" class="form-control form-control-sm mb-1">{{item.note}}</textarea><button class="btn btn-success btn-sm w-100 py-0">Lưu</button></form>
                        {% endif %}
                    </td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
    <script>
        function openE(k){document.getElementById('d-'+k).className='d-none'; document.getElementById('f-'+k).style.display='block';}
        function showT(k){document.getElementById('t-'+k).style.display='block';}
        function formatCur(i){let v=i.value.replace(/\D/g,""); if(v!=="")i.value=Number(v).toLocaleString('en-US');}
    </script>
</body>
</html>
