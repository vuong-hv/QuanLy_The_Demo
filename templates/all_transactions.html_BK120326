<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>Chi tiết giao dịch</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
    <style>
        body { font-size: 10px; background-color: #f8f9fa; }
        thead { background: #212529; color: white; white-space: nowrap; position: sticky; top: 0; z-index: 10; }
        .money { text-align: right; font-weight: bold; }
        .filter-card { background: #fff; border-top: 3px solid #0d6efd; border-radius: 8px; }
        .btn-action { padding: 1px 5px; font-size: 10px; font-weight: bold; }
    </style>
</head>
<body class="p-2">
    <div class="d-flex justify-content-between align-items-center mb-2">
        <h6 class="fw-bold m-0 text-uppercase">📜 Chi tiết mọi giao dịch</h6>
        <div class="btn-group">
            <a href="/report_chu" class="btn btn-outline-primary btn-sm py-0">Báo cáo</a>
            <a href="/" class="btn btn-primary btn-sm py-0">Quay lại</a>
        </div>
    </div>

    <!-- THANH BỘ LỌC 4 CẤP -->
    <div class="card filter-card p-2 mb-2 shadow-sm">
        <form action="/all_transactions" method="get" class="row g-1">
            <div class="col-3"><input type="date" name="date" class="form-control form-control-sm" value="{{sel_date}}" style="font-size: 9px;"></div>
            <div class="col-3">
                <select name="chu_pos" id="chu-select" class="form-select form-select-sm" style="font-size: 9px;">
                    <option value="Tất cả">-- Chủ --</option>
                    {% for c in list_chu %}<option value="{{c}}" {% if sel_chu == c %}selected{% endif %}>{{c}}</option>{% endfor %}
                </select>
            </div>
            <div class="col-3">
                <select name="cong_ty" class="form-select form-select-sm" style="font-size: 9px;">
                    <option value="Tất cả">-- Công ty --</option>
                    {% for c in list_cty %}<option value="{{c}}" {% if sel_cty == c %}selected{% endif %}>{{c}}</option>{% endfor %}
                </select>
            </div>
            <div class="col-3">
                <select name="may_pos" id="may-select" class="form-select form-select-sm" style="font-size: 9px;">
                    <option value="Tất cả">-- Máy --</option>
                </select>
            </div>
            <div class="col-12 mt-1"><button type="submit" class="btn btn-dark btn-sm w-100 py-1 fw-bold">TÌM KIẾM CHI TIẾT</button></div>
        </form>
    </div>

    <!-- BẢNG DANH SÁCH -->
    <div class="table-responsive bg-white rounded shadow-sm">
        <table class="table table-bordered table-hover table-sm mb-0">
            <thead>
                <tr>
                    <th>Ngày</th><th>Chủ</th><th>Cty</th><th>Máy</th><th>Lô</th><th>Tiền</th><th>Thực</th><th>Lãi</th><th>HĐ</th>
                </tr>
            </thead>
            <tbody>
                {% for row in transactions %}
                <tr>
                    <td class="text-center small">{{ row['Chi tiết ngày tháng'] }}</td>
                    <td class="fw-bold">{{ row['Tên Chủ POS'] }}</td>
                    <td class="small">{{ row['Tên Công ty'] }}</td>
                    <td class="small text-muted">{{ row['Máy POS'] }}</td>
                    <td class="text-center fw-bold text-danger">{{ row['Số Lô'] }}</td>
                    <td class="money">{{ "{:,.0f}".format(row['Số tiền']) }}</td>
                    <td class="money text-primary">{{ "{:,.0f}".format(row['Thực chuyển']) }}</td>
                    <td class="money {% if row['Lãi/Lỗ'] < 0 %}text-danger{% endif %}">{{ "{:,.0f}".format(row['Lãi/Lỗ']) }}</td>
                    <td class="text-center">
                        <div class="d-flex gap-1 justify-content-center">
                            <a href="/edit_transaction/{{ row['original_idx'] }}" class="btn btn-warning btn-action">S</a>
                            <a href="/delete_transaction/{{ row['original_idx'] }}" class="btn btn-danger btn-action" onclick="return confirm('Xóa?')">X</a>
                        </div>
                    </td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>

    <script>
        const ownerMap = {{ owner_map | tojson }};
        const selMay = "{{ sel_may }}";
        const chuSelect = document.getElementById('chu-select');
        const maySelect = document.getElementById('may-select');

        function updateMachines(owner) {
            maySelect.innerHTML = '';
            if (owner === "Tất cả") {
                let opt = new Option("-- Máy --", "Tất cả"); maySelect.add(opt);
                let all = new Set(); Object.values(ownerMap).forEach(list => list.forEach(m => all.add(m)));
                all.forEach(m => { let o = new Option(m, m); if(m===selMay) o.selected=true; maySelect.add(o); });
            } else {
                const machines = ownerMap[owner] || [];
                machines.forEach(m => { let o = new Option(m, m); if(m===selMay) o.selected=true; maySelect.add(o); });
            }
        }
        chuSelect.addEventListener('change', (e) => updateMachines(e.target.value));
        updateMachines(chuSelect.value);
    </script>
</body>
</html>
