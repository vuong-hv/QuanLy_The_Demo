<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Chi tiết giao dịch</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
    <style>
        body { font-size: 10px; background-color: #f8f9fa; }
        thead { background: #212529; color: white; white-space: nowrap; position: sticky; top: 0; }
        .money { text-align: right; }
        .unassigned { color: red; font-weight: bold; }
    </style>
</head>
<body class="p-2">
    <div class="d-flex justify-content-between align-items-center mb-2">
        <h6 class="fw-bold m-0">📜 CHI TIẾT GIAO DỊCH</h6>
        <div class="btn-group">
            <a href="/report" class="btn btn-outline-primary btn-sm">Báo cáo</a>
            <a href="/" class="btn btn-primary btn-sm">Quay lại</a>
        </div>
    </div>

    <div class="table-responsive bg-white shadow-sm rounded">
        <table class="table table-bordered table-hover table-sm mb-0">
            <thead>
                <tr>
                    <th>Ngày</th>
                    <th>Chủ</th>
                    <th>Công ty</th>
                    <th>Máy POS</th>
                    <th>Tiền</th>
                    <th>Thực</th>
                    <th>Lãi</th>
                    <th>HĐ</th>
                </tr>
            </thead>
            <tbody>
                {% for row in transactions %}
                <tr>
                    <td>{{ row['Chi tiết ngày tháng'] }}</td>
                    <td>{{ row['Tên Chủ POS'] }}</td>
                    <td class="{% if row['Tên Công ty'] == 'Chưa gán' or row['Tên Công ty'] == 'N/A' %}unassigned{% endif %}">
                        {{ row['Tên Công ty'] }}
                    </td>
                    <td>{{ row['Máy POS'] }}</td>
                    <td class="money">{{ "{:,.0f}".format(row['Số tiền']) }}</td>
                    <td class="money text-primary">{{ "{:,.0f}".format(row['Thực chuyển']) }}</td>
                    <td class="money {% if row['Lãi/Lỗ'] < 0 %}text-danger{% endif %}">{{ "{:,.0f}".format(row['Lãi/Lỗ']) }}</td>
                    <td class="text-center">
                        <div class="d-flex gap-1">
                            <a href="/edit_transaction/{{ row['index'] }}" class="btn btn-warning btn-sm py-0 px-1 fw-bold">Sửa</a>
                            <a href="/delete_transaction/{{ row['index'] }}" class="btn btn-danger btn-sm py-0 px-1" onclick="return confirm('Xóa dòng này?')">X</a>
                        </div>
                    </td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
</body>
</html>
